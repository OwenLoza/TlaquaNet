# ============================================================
# TlaquaNet — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# PostgreSQL connection string
# Local:   postgresql://postgres:postgres@localhost:5432/tlaquanet
# Remote:  Get this from your hosting provider (Neon, Render, etc.)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tlaquanet
